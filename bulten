  <div class="breaking-banner" style="background:#0d1a2a"><span class="breaking-label" style="background:#2980b9">Tech</span><span class="breaking-ticker" style="color:rgba(255,255,255,0.7)"></span></div>
  <div class="masthead" style="background:#0d1a2a;border-bottom:4px solid #2980b9"><div class="masthead-logo" style="color:#fff">Tech<span style="color:#2980b9">Pulse</span></div><div class="masthead-right" style="color:#aaa"><strong style="color:#fff">Teknoloji</strong><br/>The Verge Tech<br/>⏱ ~6 dakika</div></div>
  <div class="page-label" style="background:#2980b9"><span>💻 Sayfa 3 — Teknoloji</span><span class="pl-right">0 haber</span></div>
  <div class="p3-wrap">
    <p style="padding:20px">Bu hafta teknoloji haberi bulunamadı.</p>
  </div>
  <div class="next-teaser" style="background:linear-gradient(transparent,rgba(13,26,40,0.9) 60%)"><div><div class="nt-label">Son sayfa</div><div class="nt-title">Yatırım & Girişim</div></div><div class="nt-arrow">›</div></div>
</div>

<div class="page next" data-page="3">
  <div class="breaking-banner" style="background:#0d1a0d"><span class="breaking-label" style="background:#27ae60">Para</span><span class="breaking-ticker" style="color:rgba(255,255,255,0.7)"></span></div>
  <div class="masthead" style="background:#0d1a0d;border-bottom:4px solid #27ae60"><div class="masthead-logo" style="color:#fff">Tech<span style="color:#27ae60">Pulse</span></div><div class="masthead-right" style="color:#aaa"><strong style="color:#fff">Yatırım & Girişim</strong><br/>TechCrunch Venture<br/>⏱ ~4 dakika</div></div>
  <div class="page-label" style="background:#27ae60"><span>💰 Sayfa 4 — Yatırım</span><span class="pl-right">0 haber</span></div>
  <div class="p4-wrap">
    <div class="p4-header"><h2>Bu Haftanın Yatırımları</h2><p>TechCrunch Venture · 9 Nisan 2026</p></div>
    <div class="vc-grid"></div>
    
  </div>
</div>

</div>
<script>
const pages = document.querySelectorAll('.page');
const prevBtn = document.getElementById('prevBtn');
const nextBtn = document.getElementById('nextBtn');
const dotsWrap = document.getElementById('pageDots');
const rpBar = document.getElementById('rpBar');
const sessionText = document.getElementById('sessionText');
const popup = document.getElementById('popup');
const vo = document.getElementById('vo');
const voTitle = document.getElementById('voTitle');
const pressRing = document.getElementById('pressRing');
let current = 0, animating = false;
const readPages = new Set([0]);

pages.forEach((_, i) => {
  const d = document.createElement('div');
  d.className = 'dot' + (i === 0 ? ' active' : '');
  d.addEventListener('click', () => goTo(i));
  dotsWrap.appendChild(d);
});

function updateDots() {
  document.querySelectorAll('.dot').forEach((d, i) => {
    d.classList.remove('active','read');
    if (i === current) d.classList.add('active');
    else if (readPages.has(i)) d.classList.add('read');
  });
}

function updateProgress() {
  const pct = (current / (pages.length - 1)) * 100;
  rpBar.style.width = pct + '%';
  const mins = [8, 6, 5, 4];
  const remaining = mins.slice(current).reduce((a,b) => a+b, 0);
  sessionText.textContent = 'Sayfa ' + (current+1) + ' / ' + pages.length + ' · ~' + remaining + ' dk kaldi';
}

function goTo(t) {
  if (animating || t === current || t < 0 || t >= pages.length) return;
  animating = true;
  const dir = t > current ? 1 : -1;
  const oldP = pages[current], newP = pages[t];
  newP.style.transition = 'none';
  newP.style.transform = 'translateX(' + (dir * 100) + '%)';
  newP.style.opacity = '0';
  newP.style.zIndex = '10';
  newP.style.pointerEvents = 'none';
  newP.offsetHeight;
  newP.style.transition = 'transform 0.65s cubic-bezier(.77,0,.18,1), opacity 0.65s ease';
  newP.style.transform = 'translateX(0)';
  newP.style.opacity = '1';
  oldP.style.transition = 'transform 0.65s cubic-bezier(.77,0,.18,1), opacity 0.65s ease';
  oldP.style.transform = 'translateX(' + (dir * -60) + '%) scale(0.93)';
  oldP.style.opacity = '0';
  oldP.style.zIndex = '5';
  setTimeout(() => {
    oldP.className = 'page ' + (t > current ? 'prev' : 'next');
    oldP.style.cssText = '';
    newP.className = 'page active';
    newP.style.cssText = '';
    current = t;
    readPages.add(current);
    updateDots();
    updateProgress();
    updateNav();
    animating = false;
  }, 660);
}

function updateNav() {
  prevBtn.classList.toggle('disabled', current === 0);
  nextBtn.classList.toggle('disabled', current === pages.length - 1);
}

prevBtn.addEventListener('click', () => goTo(current - 1));
nextBtn.addEventListener('click', () => goTo(current + 1));
document.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') goTo(current + 1);
  if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') goTo(current - 1);
});

let tx = 0, ty = 0;
document.addEventListener('touchstart', e => { tx = e.touches[0].clientX; ty = e.touches[0].clientY; }, {passive:true});
document.addEventListener('touchend', e => {
  const dx = e.changedTouches[0].clientX - tx;
  const dy = Math.abs(e.changedTouches[0].clientY - ty);
  if (Math.abs(dx) > 50 && dy < 80) { dx < 0 ? goTo(current+1) : goTo(current-1); }
}, {passive:true});

let wCool = false;
document.addEventListener('wheel', e => {
  if (wCool) return;
  if (Math.abs(e.deltaX) > Math.abs(e.deltaY) && Math.abs(e.deltaX) > 30) {
    wCool = true;
    e.deltaX > 0 ? goTo(current+1) : goTo(current-1);
    setTimeout(() => wCool = false, 800);
  }
}, {passive:true});

let hoverT;
function showPopup(el, e) {
  document.getElementById('popupTitle').textContent = el.dataset.title || '';
  document.getElementById('popupText').textContent = el.dataset.curiosity || '';
  posPopup(e);
  popup.classList.add('show');
}
function posPopup(e) {
  const pw = 250, ph = 120;
  let x = e.clientX + 14, y = e.clientY - 10;
  if (x + pw > window.innerWidth) x = e.clientX - pw - 14;
  if (y + ph > window.innerHeight) y = window.innerHeight - ph - 10;
  popup.style.left = x + 'px';
  popup.style.top = y + 'px';
}
document.querySelectorAll('[data-title]').forEach(el => {
  el.addEventListener('mouseenter', e => { hoverT = setTimeout(() => showPopup(el, e), 250); });
  el.addEventListener('mousemove', e => posPopup(e));
  el.addEventListener('mouseleave', () => { clearTimeout(hoverT); popup.classList.remove('show'); });
  el.addEventListener('click', () => { const u = el.dataset.url; if (u && u !== '#') window.open(u, '_blank'); });
});

let pressT = null;
function startPress(el, cx, cy) {
  if (!el.dataset.video) return;
  pressRing.style.left = (cx - 28) + 'px';
  pressRing.style.top = (cy - 28) + 'px';
  pressRing.className = 'press-ring';
  void pressRing.offsetWidth;
  pressRing.classList.add('active');
  pressT = setTimeout(() => {
    pressRing.className = 'press-ring';
    voTitle.textContent = el.dataset.title || '';
    vo.classList.add('show');
  }, 750);
}
function cancelPress() {
  clearTimeout(pressT); pressT = null;
  pressRing.className = 'press-ring';
}
document.querySelectorAll('[data-video="true"]').forEach(el => {
  el.addEventListener('mousedown', e => startPress(el, e.clientX, e.clientY));
  el.addEventListener('mouseup', cancelPress);
  el.addEventListener('mouseleave', cancelPress);
  el.addEventListener('touchstart', e => { const t = e.touches[0]; startPress(el, t.clientX, t.clientY); }, {passive:true});
  el.addEventListener('touchend', cancelPress, {passive:true});
  el.addEventListener('touchmove', cancelPress, {passive:true});
});
document.getElementById('voClose').addEventListener('click', () => vo.classList.remove('show'));
vo.addEventListener('click', e => { if (e.target === vo) vo.classList.remove('show'); });
updateProgress();
updateNav();
</script>
</body>
</html>