<script>
(function(){
  const book = document.getElementById('book');
  const pages = book.querySelectorAll('.page');

  function getDims(){
  const vw = window.innerWidth;
  const vh = window.innerHeight;
  const ctrlH = 60;
  const availH = vh - ctrlH - 20;
  const availW = vw - 20;
  // PageFlip çift sayfa gösterir, tek sayfa genişliği toplam genişliğin yarısı
  let w = Math.min(520, Math.floor(availW / 2));
  let h = Math.min(Math.floor(w * 1.42), availH);
  if (h < 320) { h = 320; w = Math.floor(h / 1.42); }
  if (w * 2 > availW) { w = Math.floor(availW / 2); }
  return { w, h };
}

  const dims = getDims();

  const flip = new St.PageFlip(book, {
    width: dims.w,
    height: dims.h,
    size: 'fixed',
    showCover: true,
    usePortrait: true,
    flippingTime: 800,
    maxShadowOpacity: 0.5,
    mobileScrollSupport: false,
  });

  flip.loadFromHTML(pages);

  const btnPrev = document.getElementById('btnPrev');
  const btnNext = document.getElementById('btnNext');
  const info    = document.getElementById('pg-info');

  function label(idx, total){
    if (idx === 0) return 'Kapak';
    if (idx === total - 1) return 'Arka Kapak';
    return 'Sayfa ' + (idx + 1);
  }

  function sync(idx){
    const total = flip.getPageCount();
    btnPrev.disabled = idx <= 0;
    btnNext.disabled = idx >= total - 1;
    info.textContent = label(idx, total);
  }

  flip.on('flip', e => sync(e.data));

  btnPrev.addEventListener('click', () => {
    if (!btnPrev.disabled) flip.flipPrev('bottom');
  });
  btnNext.addEventListener('click', () => {
    if (!btnNext.disabled) flip.flipNext('bottom');
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft')  btnPrev.click();
    if (e.key === 'ArrowRight') btnNext.click();
  });

  sync(0);

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => location.reload(), 400);
  });
})();
</script>

