  text-transform:uppercase;
  color:var(--red);
  margin-bottom:4px;
}
.art h3{
  font-family:var(--fh);
  font-size:1.15rem;
  font-weight:700;
  line-height:1.25;
  margin-bottom:6px;
}
.art p{
  font-size:.98rem;
  line-height:1.6;
  color:var(--ink-med);
  text-align:justify;
}
.art p.dc::first-letter{
  font-family:var(--fh);
  font-size:2.4em;
  float:left;
  line-height:.78;
  margin:3px 7px 0 0;
  color:var(--red);
  font-weight:900;
}
.art-by{
  font-family:var(--fm);
  font-size:.78rem;
  color:var(--ink-faint);
  margin-top:4px;
}
.art-img{
