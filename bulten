<script>
(function () {
  const isMobile = () => window.innerWidth <= 768;
  const isSmall  = () => window.innerWidth <= 480;

  function setHint() {
    const el = document.getElementById('hint');
    el.textContent = isMobile() ? 'Sayfayı kaydır →' : '← → tuşları veya sürükle';
  }
  setHint();

  function dims() {
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const ctrlH = isSmall() ? 48 : (isMobile() ? 54 : 60);
    const availH = vh - ctrlH;
    const availW = vw;
    let w, h;
    if (isMobile()) {
      w = availW - 16;
      h = availH - 12;
      const maxH = Math.floor(w * 1.35);
      if (h > maxH) h = maxH;
      const maxW = Math.floor(h / 1.35);
      if (w > maxW) w = maxW;
    } else {
      w = Math.floor((availW - 24) / 2);
      h = Math.floor(w * 1.35);
      if (h > availH - 10) { h = availH - 10; w = Math.floor(h / 1.35); }
      w = Math.min(w, 960);
      h = Math.min(h, 900);
    }
    w = Math.max(260, w);
    h = Math.max(340, h);
    return { w, h };
  }

  const { w, h } = dims();

  const pageFlip = new St.PageFlip(
    document.getElementById('book'),
    {
      width:  w, height: h, size: 'fixed',
      showCover: false, drawShadow: true,
      flippingTime: isMobile() ? 600 : 800,
      usePortrait: true,
      maxShadowOpacity: isMobile() ? 0.3 : 0.5,
      mobileScrollSupport: false,
      autoSize: true, useMouseEvents: true, startZIndex: 0,
    }
  );

  pageFlip.loadFromHTML(document.querySelectorAll('.page'));

  const LABELS = ['Kapak', 'Yapay Zeka', 'AI Devam', 'Teknoloji', 'Teknoloji Devam', 'Venture', 'Arka Kapak'];

  function getLabel(idx) {
    const total = pageFlip.getPageCount();
    if (idx >= total - 1) return 'Arka Kapak';
    return LABELS[idx] || ('Sayfa ' + (idx + 1));
  }

  function sync(idx) {
    const total = pageFlip.getPageCount();
    const atStart = idx === 0;
    const atEnd = isMobile() ? idx >= total - 1 : idx >= total - 2;
    document.getElementById('btnPrev').classList.toggle('off', atStart);
    document.getElementById('btnNext').classList.toggle('off', atEnd);
    document.getElementById('pg-info').textContent = getLabel(idx);
  }

  pageFlip.on('flip', e => sync(e.data));
  document.getElementById('btnPrev').addEventListener('click', () => pageFlip.flipPrev('bottom'));
  document.getElementById('btnNext').addEventListener('click', () => pageFlip.flipNext('bottom'));
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') pageFlip.flipNext('bottom');
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   pageFlip.flipPrev('bottom');
  });

  sync(0);

  let resizeTimer;
  function onResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => location.reload(), 350);
  }
  window.addEventListener('resize', onResize);
  window.addEventListener('orientationchange', onResize);
}());
</script>
