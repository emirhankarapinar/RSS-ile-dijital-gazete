  font-family:var(--fm);
  font-size:.78rem;
  color:var(--ink-faint);
  letter-spacing:4px;
  margin-top:6px;
}
.stats{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  border-top:1px solid var(--rule-lt);
  border-bottom:1px solid var(--rule-lt);
