<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,user-scalable=no"/>
<meta name="description" content="TechPulse Gazette — Teknoloji haberleri."/>
<title>TechPulse Gazette — 16 Nisan 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Special+Elite&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/page-flip/dist/js/page-flip.browser.min.js"></script>
<style>
:root {
  --paper:      #f2edd8;
  --paper-warm: #ede5c8;
  --ink:        #160f04;
  --ink-med:    #362a18;
  --ink-lt:     #6b5c40;
  --ink-faint:  #9c8b6e;
  --rule:       #281e0a;
  --rule-lt:    #bdb090;
  --red:        #8b1508;
  --fh: 'Playfair Display', Georgia, serif;
  --fb: 'Lora', 'Times New Roman', serif;
  --fm: 'Special Elite', 'Courier New', monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { height: 100%; }
body {
  height: 100%;
  background: radial-gradient(ellipse at 50% 50%, #3a3020, #1a1408);
  font-family: var(--fb);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
}
#stage {
  position: fixed; inset: 0 0 56px 0;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.page {
  background-color: var(--paper);
  background-image:
    radial-gradient(circle at center, transparent 40%, rgba(160, 130, 70, 0.12) 130%),
    repeating-linear-gradient(90deg, transparent, transparent 14px, rgba(140, 115, 60, 0.015) 14px, rgba(140, 115, 60, 0.015) 15px),
    repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.018) 2px, rgba(0, 0, 0, 0.018) 3px);
  overflow: hidden;
  font-family: var(--fb);
  color: var(--ink);
}
.page-warm {
  background-color: var(--paper-warm);
  background-image:
    radial-gradient(circle at center, transparent 35%, rgba(160, 130, 70, 0.18) 120%),
    repeating-linear-gradient(90deg, transparent, transparent 14px, rgba(140, 115, 60, 0.015) 14px, rgba(140, 115, 60, 0.015) 15px),
    repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.018) 2px, rgba(0, 0, 0, 0.018) 3px);
}
.inner {
  width: 100%; height: 100%;
  display: flex; flex-direction: column;
  padding: 20px 22px 14px;
  overflow: hidden;
}
a.art-link { color: inherit; text-decoration: none; transition: color .15s; }
a.art-link:hover { color: var(--red); }
a.art-link:hover h3 { color: var(--red); text-decoration: underline; }

/* ── Resim stilleri ── */
.art-img, .hl-img, .cov-img {
  width: 100%; overflow: hidden; border-radius: 2px;
  margin-bottom: 7px; flex-shrink: 0;
  background: rgba(0,0,0,.05);
}
.art-img { max-height: 100px; }
.hl-img  { max-height: 140px; }
.cov-img { max-height: 160px; }
.art-img img, .hl-img img, .cov-img img {
  width: 100%; height: 100%; object-fit: cover; display: block;
}

/* NAMEPLATE */
.nameplate { text-align: center; border-bottom: 3px double var(--rule); padding-bottom: 10px; margin-bottom: 10px; flex-shrink: 0; }
.np-row { display: flex; justify-content: space-between; font-family: var(--fm); font-size: .88rem; color: var(--ink-faint); margin-bottom: 3px; }
.np-title { font-family: var(--fh); font-size: clamp(1.8rem, 5.5vw, 3rem); font-weight: 900; line-height: 1; }
.np-sub { font-family: var(--fh); font-size: .92rem; font-style: italic; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-lt); }
.np-rule { display: flex; align-items: center; gap: 8px; margin-top: 6px; }
.np-rule::before, .np-rule::after { content: ''; flex: 1; height: 1px; background: var(--rule-lt); }
.np-rule span { font-family: var(--fm); font-size: .82rem; color: var(--ink-faint); }

/* SEC */
.sec { background: var(--ink); color: var(--paper); padding: 5px 14px; font-family: var(--fh); font-size: 1rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; margin-bottom: 10px; }
.sec-r { font-family: var(--fm); font-size: .78rem; font-weight: 400; opacity: .5; text-transform: none; }

/* HL */
.hl { padding-bottom: 10px; border-bottom: 2px solid var(--rule); margin-bottom: 10px; flex-shrink: 0; }
.hl-tag { display: inline-block; background: var(--red); color: #fff; font-family: var(--fm); font-size: .82rem; padding: 3px 10px; margin-bottom: 6px; letter-spacing: .06em; text-transform: uppercase; }
.hl h2 { font-family: var(--fh); font-size: clamp(1.3rem, 3.5vw, 2rem); font-weight: 900; line-height: 1.12; margin-bottom: 6px; }
.hl-sub { font-family: var(--fh); font-size: 1.05rem; font-style: italic; color: var(--ink-med); line-height: 1.45; }
.hl-by { font-family: var(--fm); font-size: .82rem; color: var(--ink-faint); margin-top: 6px; }

/* COLS */
.cols { columns: 2; column-gap: 16px; column-rule: 1px solid var(--rule-lt); flex: 1; overflow: hidden; }

/* ART */
.art { break-inside: avoid; margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid var(--rule-lt); }
.art:last-child { border-bottom: none; margin-bottom: 0; }
.art-cat { font-family: var(--fm); font-size: .82rem; letter-spacing: .06em; text-transform: uppercase; color: var(--red); margin-bottom: 4px; }
.art h3 { font-family: var(--fh); font-size: 1.2rem; font-weight: 700; line-height: 1.2; margin-bottom: 6px; }
.art p { font-size: 1.02rem; line-height: 1.6; color: var(--ink-med); text-align: justify; hyphens: auto; }
.art p.dc::first-letter { font-family: var(--fh); font-size: 2.6em; float: left; line-height: .78; margin: 3px 7px 0 0; color: var(--red); font-weight: 900; }
.art-by { font-family: var(--fm); font-size: .78rem; color: var(--ink-faint); margin-top: 5px; }
.orn { text-align: center; font-size: .82rem; color: var(--ink-faint); padding: 6px 0; letter-spacing: 5px; flex-shrink: 0; }

/* STATS */
.stats { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid var(--rule-lt); border-bottom: 1px solid var(--rule-lt); margin-bottom: 10px; flex-shrink: 0; }
.st { text-align: center; padding: 8px 4px; border-right: 1px solid var(--rule-lt); }
.st:last-child { border-right: none; }
.st-n { font-family: var(--fh); font-size: clamp(1.2rem, 2.8vw, 1.8rem); font-weight: 900; color: var(--red); line-height: 1; }
.st-l { font-family: var(--fm); font-size: .7rem; text-transform: uppercase; color: var(--ink-faint); margin-top: 3px; }

/* TABLE */
.tbl { width: 100%; border-collapse: collapse; }
.tbl th { font-family: var(--fm); font-size: .78rem; text-transform: uppercase; text-align: left; padding: 6px 7px; border-bottom: 2px solid var(--rule); color: var(--ink-lt); }
.tbl td { padding: 7px 7px; border-bottom: 1px solid var(--rule-lt); vertical-align: top; font-size: .92rem; }
.tbl tr:last-child td { border-bottom: none; }
.tbl .amt { font-family: var(--fh); font-weight: 900; color: var(--red); font-size: 1.05rem; }
.tbl .co  { font-family: var(--fh); font-weight: 700; font-size: 1rem; }
.tbl .dsc { color: var(--ink-faint); font-size: .85rem; font-style: italic; }

/* COVER */
.cov { display: flex; flex-direction: column; height: 100%; overflow: hidden; }
.cov-stripe { background: var(--ink); padding: 6px 20px; font-family: var(--fm); font-size: .72rem; color: rgba(242,237,216,.55); letter-spacing: .06em; text-transform: uppercase; text-align: center; flex-shrink: 0; }
.cov-nameplate { padding: 18px 20px 14px; border-bottom: 5px double var(--rule); text-align: center; flex-shrink: 0; }
.cov-nameplate .big { font-family: var(--fh); font-size: clamp(2.8rem, 8vw, 4.8rem); font-weight: 900; line-height: 1; }
.cov-nameplate .tagline { font-family: var(--fh); font-size: .92rem; font-style: italic; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-lt); margin-top: 4px; }
.cov-daterow { display: flex; justify-content: space-between; font-family: var(--fm); font-size: .78rem; color: var(--ink-faint); padding: 6px 20px; border-bottom: 1px solid var(--rule-lt); flex-shrink: 0; }
.cov-hl { padding: 14px 20px; border-bottom: 2px solid var(--rule); flex-shrink: 0; }
.cov-hl h2 { font-family: var(--fh); font-size: clamp(1.2rem, 3vw, 1.85rem); font-weight: 900; line-height: 1.12; margin-bottom: 7px; }
.cov-hl p { font-family: var(--fh); font-size: 1rem; font-style: italic; color: var(--ink-med); line-height: 1.45; }
.cov-by { font-family: var(--fm); font-size: .72rem; color: var(--ink-faint); margin-top: 6px; }
.cov-cols { columns: 2; column-gap: 16px; column-rule: 1px solid var(--rule-lt); padding: 12px 20px; flex: 1; overflow: hidden; }

/* BACK */
.back { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; padding: 32px; text-align: center; }
.back .big { font-family: var(--fh); font-size: clamp(2rem, 5vw, 3.4rem); font-weight: 900; margin-bottom: 10px; }
.back .tagline { font-family: var(--fh); font-size: .95rem; font-style: italic; color: var(--ink-lt); margin-bottom: 18px; }
.back-rule { width: 70px; height: 3px; background: var(--red); margin: 0 auto 18px; }
.back .info { font-family: var(--fm); font-size: .72rem; color: var(--ink-faint); line-height: 2; }
.back .sources { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; margin-top: 16px; }
.back .sources span { font-family: var(--fh); font-size: .78rem; font-weight: 700; font-style: italic; color: var(--ink-lt); }

/* CONTROLS */
#controls { position: fixed; bottom: 10px; left: 50%; transform: translateX(-50%); z-index: 500; display: flex; align-items: center; gap: 10px; background: rgba(22,15,4,.88); backdrop-filter: blur(10px); padding: 7px 20px; border-radius: 28px; border: 1px solid rgba(190,175,130,.2); }
.ctl { font-family: var(--fm); font-size: .72rem; color: var(--paper); background: rgba(242,237,216,.08); border: 1px solid rgba(190,175,130,.22); padding: 6px 18px; border-radius: 16px; cursor: pointer; transition: background .2s, border-color .2s; white-space: nowrap; }
.ctl:hover { background: rgba(139,21,8,.75); border-color: var(--red); }
.ctl.off { opacity: .2; pointer-events: none; }
#pg-info { font-family: var(--fm); font-size: .65rem; color: rgba(242,237,216,.5); min-width: 90px; text-align: center; }
#hint { position: fixed; top: 12px; right: 14px; z-index: 500; font-family: var(--fm); font-size: .55rem; color: rgba(242,237,216,.25); pointer-events: none; }

/* RESPONSIVE */
@media (max-width: 1024px) {
  .inner { padding: 14px 16px 10px; }
  .np-title { font-size: clamp(1.5rem, 5vw, 2.4rem); }
  .art h3 { font-size: 1.08rem; }
  .art-img { max-height: 80px; }
  .hl-img  { max-height: 110px; }
}
@media (max-width: 768px) {
  #stage { inset: 0 0 50px 0; }
  .cols { columns: 1; column-rule: none; }
  .cov-cols { columns: 1; column-rule: none; padding: 10px 14px; }
  .inner { padding: 12px 14px 8px; }
  .np-title { font-size: clamp(1.3rem, 6vw, 2rem); }
  .art h3 { font-size: 1.05rem; }
  .art p { font-size: .92rem; }
  .art-img { max-height: 120px; }
  .hl-img  { max-height: 140px; }
  .cov-img { max-height: 120px; }
  .stats { margin-bottom: 8px; }
  #controls { padding: 6px 14px; gap: 8px; bottom: 6px; }
  .ctl { font-size: .65rem; padding: 6px 14px; }
}
@media (max-width: 480px) {
  #stage { inset: 0 0 44px 0; }
  .inner { padding: 10px 10px 6px; }
  .np-title { font-size: clamp(1.1rem, 7vw, 1.8rem); }
  .art h3 { font-size: .95rem; }
  .art p { font-size: .85rem; line-height: 1.5; }
  .stats { grid-template-columns: repeat(2, 1fr); }
  .cov-nameplate .big { font-size: clamp(1.7rem, 10vw, 2.8rem); }
  .cov-daterow { flex-wrap: wrap; justify-content: center; gap: 4px; }
  #controls { padding: 5px 10px; gap: 6px; bottom: 4px; }
  .ctl { font-size: .6rem; padding: 5px 10px; }
}
</style>
</head>
