  overflow:hidden;
  display:none;
}
.page.active{display:block;}
.page-warm{
  background-color:var(--paper-warm);
}
.inner{
  width:100%;height:100%;
  padding:20px 22px 16px;
  display:flex;flex-direction:column;
}
.nameplate{
  text-align:center;
  border-bottom:3px double var(--rule);
  padding-bottom:10px;
  margin-bottom:10px;
}
.np-row{
  display:flex;
  justify-content:space-between;
  font-family:var(--fm);
  font-size:.86rem;
  color:var(--ink-faint);
  margin-bottom:4px;
}
.np-title{
  font-family:var(--fh);
  font-size:clamp(1.8rem,5vw,3rem);
  font-weight:900;
  line-height:1;
}
.np-sub{
  font-family:var(--fh);
  font-size:.9rem;
  font-style:italic;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--ink-lt);
}
.np-rule{
  display:flex;
  align-items:center;
  gap:8px;
  margin-top:6px;
}
.np-rule::before,
.np-rule::after{
  content:'';
  flex:1;
  height:1px;
  background:var(--rule-lt);
}
.np-rule span{
  font-family:var(--fm);
  font-size:.78rem;
  color:var(--ink-faint);
}
.sec{
  background:var(--ink);
  color:var(--paper);
  padding:6px 14px;
  font-family:var(--fh);
  font-size:.96rem;
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin:10px 0;
}
.sec-r{
  font-family:var(--fm);
  font-size:.76rem;
  opacity:.8;
}
.hl{
  padding-bottom:10px;
